#: includes/class-wc-morkva-mono-gateway.php:114
#| msgid ""
#| "<br>After receiving the API token and activating your merchant, write to "
#| "Monobank's support chat<br> to activate a redirect to the site's thank "
#| "you page (the plugin transmits the page URL via API).<br> Tell support "
#| "that you are using the Morkva plugin."
msgid ""
"<br>After receiving the API token and activating your merchant, write to "
"Monobank's support chat<br> to activate a redirect to the site's thank you "
"page (the plugin transmits the page URL via API).<br> Tell support that you "
"are using the morkva plugin."
msgstr ""
"<br>After receiving the API token and activating your merchant, write to "
"Monobank's support chat<br> to activate a redirect to the site's thank you "
"page (the plugin transmits the page URL via API).<br> Tell support that you "
"are using the morkva plugin."

