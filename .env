WORDPRESS_PORT=8080
ADMINER_PORT=8081

# Auto-install plugins from the public WordPress plugin repository.
# Premium or custom plugins must be installed manually.
WP_AUTO_PLUGINS=cyr2lat,debug-log-viewer,disable-gutenberg,disable-comments,all-in-one-wp-migration,woocommerce
COMPOSE_PROJECT_NAME=rasti
PROJECT_NAME=rasti
SITE_NAME=rasti
SITE_HOST=localhost
DEV_SITE_URL=http://localhost:8080
THEME_NAME=Rasti Theme
THEME_TEXT_DOMAIN=rasti-theme
